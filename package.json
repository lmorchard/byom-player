{
  "name": "@lmorchard/byom-player",
  "version": "1.0.2",
  "description": "A framework-agnostic Lit web component that plays JSPF playlists through swappable audio providers.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lmorchard/byom-player.git"
  },
  "homepage": "https://github.com/lmorchard/byom-player#readme",
  "bugs": "https://github.com/lmorchard/byom-player/issues",
  "type": "module",
  "main": "./dist/byom-player.js",
  "module": "./dist/byom-player.js",
  "files": [
    "dist/*.js"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:pages": "vite build --config vite.pages.config.ts",
    "preview:pages": "vite preview --config vite.pages.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . && prettier --check \"**/*.{ts,js,json,md}\"",
    "format": "prettier --write \"**/*.{ts,js,json,md}\""
  },
  "dependencies": {
    "@lit-labs/virtualizer": "^2.1.1",
    "lit": "^3.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "eslint": "^9.17.0",
    "happy-dom": "^15.11.7",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
